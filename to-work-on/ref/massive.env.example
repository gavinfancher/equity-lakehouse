# Template for massive.env (which is gitignored).
# Copy to massive.env and fill in your Massive flatfiles credentials.

export MASSIVE_ACCESS_KEY="<your-access-key>"
export MASSIVE_SECRET_KEY="<your-secret-key>"

export AWS_ACCESS_KEY_ID="$MASSIVE_ACCESS_KEY"
export AWS_SECRET_ACCESS_KEY="$MASSIVE_SECRET_KEY"
