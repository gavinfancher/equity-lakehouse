# Copy to config.env and edit. Never commit config.env.
# Usage: source ref/config.env  (scripts source this automatically)

# --- Project ---
PROJECT_ID="your-gcp-project-id"
REGION="us-central1"
ZONE="us-central1-a"

# --- Storage ---
LAKEHOUSE_BUCKET="your-lakehouse-bucket"   # must match CATALOG_NAME
DATA_BUCKET="your-data-bucket"
CATALOG_NAME="${LAKEHOUSE_BUCKET}"

# --- Service account ---
SA_NAME="finpipe-sa"
SA_EMAIL="${SA_NAME}@${PROJECT_ID}.iam.gserviceaccount.com"
SA_KEY_PATH="${PWD}/sa-key.json"

# --- Cloud Run ingest ---
AR_REPO="finpipe"
CLOUD_RUN_IMAGE="${REGION}-docker.pkg.dev/${PROJECT_ID}/${AR_REPO}/ingest:latest"
CLOUD_RUN_JOB="finpipe-backfill"

# --- VM (optional) ---
VM_NAME="finpipe-vm"
VM_MACHINE_TYPE="e2-medium"
VM_IMAGE="projects/debian-cloud/global/images/family/debian-12"
VM_IMAGE_PROJECT="debian-cloud"
VM_DISK_SIZE="50GB"
VM_DISK_TYPE="pd-balanced"
SSH_USER="your-linux-username"
SSH_PUBKEY_PATH="${HOME}/.ssh/id_ed25519.pub"

# --- Network ---
SSH_SOURCE_RANGES="0.0.0.0/0"
